library(bruceR)
library(readxl)
library(readr)

###read file
data <- read_excel('D:\\data.xlsx', na="")
data <- data %>%
    mutate(
        study_std = as.numeric(scale(study)),
        depression_std = as.numeric(scale(depression)),
        anxiety_std = as.numeric(scale(anxiety)),
        Grit_std = as.numeric(scale(Grit)),
        RenzhicP_std = as.numeric(scale (RenzhicP)),
        PTSD_std = as.numeric(scale(PTSD))
)
###Mediation analysis
PROCESS (data, y="depression_std", x="study_std", meds='PTSD_std', covs = c(sex', 'age' ), ci=lboot', nsim=1000, seed=1234)
PROCESS(data, y="depression_std", x="study_std", mods='RenzhicP_std', covs = c('sex', age'), ci='boot',nsim=1000, seed=1234)


###Hierarchical regression analysis
#step1
model1 <- lm(depression_std ~ sex + age + study_std, data = data)
#step2
model2 <- lm(depression_std ~ sex + age + study_std + Grit_std, data = data)
#Step3:协变量+X+w+Xxw(交互项)
model3 <- lm(depression_std ~ sex + age + study_std  Grit_std, data = data)

anova(model1, model2, model3)
summary (model1)
summary (model2)
summary (model3)

###
model <- lm(depression_std ~ study_std*grit_std*RenzhicP_std, data = data)
summary(model)

#####Chain regulation
modl <- lm(depression_std ~ study_std*RenzhicP_std, data = data)
#Step2:M1影响M2的调节强度
#构造交互项:X:M2:M1
data$XM2 <- with(data, study_std*RenzhicP_std)
model_chain <- lm(depression_std ~ study_std + grit_std + RenzhicP_std + XM2 + XM2:grit_std, data = data)
summary(model_chain)
vif(model_chain)
